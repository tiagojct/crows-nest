<!doctype html>
<html lang="pt-PT">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Crow's Nest{% if title %} - {{ title }}{% endif %}</title>
    <meta name="description" content="{{ description or 'Resumo diário da imprensa portuguesa, com tópicos do dia, tendências e um arquivo dia a dia.' }}">
    <meta property="og:site_name" content="Crow's Nest">
    <meta property="og:title" content="Crow's Nest{% if title %} - {{ title }}{% endif %}">
    <meta property="og:type" content="website">
    <meta property="og:locale" content="pt_PT">
    <meta property="og:description" content="{{ description or 'Resumo diário da imprensa portuguesa.' }}">
    <meta name="twitter:card" content="summary">
    <style>
      :root {
        color-scheme: light dark;
        --bg: #fbfbfa;
        --surface: #ffffff;
        --surface-2: #f3f4f6;
        --text: #1b1c1f;
        --muted: #5c6370;
        --border: #e3e5e9;
        --accent: #1f6feb;
        --press: #b3541e;
        --tech: #1f6feb;
        --heat-0: #eceef1;
        --heat-1: #c6e6c8;
        --heat-2: #84cc8c;
        --heat-3: #46a657;
        --heat-4: #1f7a33;
        --radius: 12px;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #0f1115;
          --surface: #171a21;
          --surface-2: #1f232c;
          --text: #e6e8ec;
          --muted: #9aa3b2;
          --border: #2a2f3a;
          --accent: #589bff;
          --press: #e0915c;
          --tech: #589bff;
          --heat-0: #20242d;
          --heat-1: #1f4427;
          --heat-2: #2e6b39;
          --heat-3: #3f9750;
          --heat-4: #5ec46f;
        }
      }
      * { box-sizing: border-box; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        max-width: 60rem;
        margin: 0 auto;
        padding: 1.25rem 1rem 4rem;
        line-height: 1.6;
        background: var(--bg);
        color: var(--text);
      }
      a { color: var(--accent); }
      h1, h2, h3, h4 { line-height: 1.2; }
      .site-header { display: flex; flex-wrap: wrap; align-items: baseline; gap: 0.5rem 1rem; padding-bottom: 0.75rem; border-bottom: 1px solid var(--border); }
      .site-header h1 { margin: 0; font-size: 1.5rem; }
      .site-header h1 a { color: inherit; text-decoration: none; }
      .site-nav { margin-left: auto; display: flex; gap: 1rem; font-size: 0.95rem; }
      .tagline { color: var(--muted); font-size: 0.9rem; margin: 0.35rem 0 0; flex-basis: 100%; }
      main { margin-top: 1.5rem; }
      .card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.1rem 1.25rem; margin: 1.25rem 0; }
      .card > h2:first-child, .card > h3:first-child { margin-top: 0; }
      .group-press h3 { color: var(--press); }
      .group-tech h3 { color: var(--tech); }
      .muted { color: var(--muted); }
      .small { font-size: 0.88rem; }
      ul.clean { list-style: none; padding-left: 0; margin: 0; }
      ul.clean li { padding: 0.4rem 0; border-bottom: 1px solid var(--border); }
      ul.clean li:last-child { border-bottom: 0; }
      .outlet-name { font-weight: 600; }
      .chips { display: flex; flex-wrap: wrap; gap: 0.4rem; margin: 0.5rem 0 0; padding: 0; list-style: none; }
      .chip { display: inline-block; background: var(--surface-2); border: 1px solid var(--border); border-radius: 999px; padding: 0.15rem 0.7rem; font-size: 0.85rem; text-decoration: none; color: var(--text); }
      .chip:hover { border-color: var(--accent); }
      .badge { display: inline-block; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.03em; padding: 0.05rem 0.4rem; border-radius: 6px; vertical-align: middle; }
      .badge.fallback { background: #f5e8c8; color: #7a5c12; }
      @media (prefers-color-scheme: dark) { .badge.fallback { background: #4a3c14; color: #e7c66a; } }
      .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
      @media (max-width: 40rem) { .grid-2 { grid-template-columns: 1fr; } }
      .trend-row { display: flex; align-items: baseline; justify-content: space-between; gap: 0.5rem; padding: 0.3rem 0; border-bottom: 1px solid var(--border); }
      .trend-row:last-child { border-bottom: 0; }
      .trend-count { color: var(--muted); font-variant-numeric: tabular-nums; font-size: 0.85rem; white-space: nowrap; }
      .momentum-up { color: var(--heat-3); font-weight: 600; }
      .heatmap { display: grid; grid-auto-flow: column; grid-template-rows: repeat(7, 12px); gap: 3px; overflow-x: auto; padding: 0.25rem 0; }
      .heatmap .cell { width: 12px; height: 12px; border-radius: 2px; background: var(--heat-0); }
      .heatmap .cell.l1 { background: var(--heat-1); }
      .heatmap .cell.l2 { background: var(--heat-2); }
      .heatmap .cell.l3 { background: var(--heat-3); }
      .heatmap .cell.l4 { background: var(--heat-4); }
      .legend { display: flex; align-items: center; gap: 4px; font-size: 0.8rem; color: var(--muted); margin-top: 0.4rem; }
      .legend .cell { width: 12px; height: 12px; border-radius: 2px; display: inline-block; }
      .sparkline { display: block; }
      .sparkline polyline { fill: none; stroke: var(--accent); stroke-width: 2; }
      .sparkline circle { fill: var(--accent); }
      .date-list { columns: 2 12rem; gap: 1.5rem; }
      .date-list li { margin: 0.2rem 0; }
      .search-box { width: 100%; padding: 0.6rem 0.8rem; font-size: 1rem; border: 1px solid var(--border); border-radius: var(--radius); background: var(--surface); color: var(--text); }
      .back { font-size: 0.9rem; }
      footer { margin-top: 3rem; padding-top: 1rem; border-top: 1px solid var(--border); color: var(--muted); font-size: 0.85rem; }
    </style>
  </head>
  <body>
    <header class="site-header">
      <h1><a href="/">Crow's Nest</a></h1>
      <nav class="site-nav">
        <a href="/">Hoje</a>
        <a href="/topics/">Tópicos</a>
        <a href="/archive/">Arquivo</a>
        <a href="/search/">Pesquisa</a>
      </nav>
      <p class="tagline">Resumo diário da imprensa portuguesa, construído a partir de metadados de RSS.</p>
    </header>
    <main>
      {{ content | safe }}
    </main>
    <footer>
      <p>Resumos gerados apenas a partir de títulos e descrições curtas de RSS. Cada meio remete para a sua fonte. Sem qualquer afiliação com os meios citados.</p>
    </footer>
  </body>
</html>
